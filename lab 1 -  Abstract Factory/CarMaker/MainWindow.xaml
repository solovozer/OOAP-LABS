<Window x:Class="CarMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarMaker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="10" Height="200" Width="300">
            <TextBlock Text="Car Maker 1.0" FontSize="24" FontWeight="Bold" Foreground="#2D2D2D" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Select factory:" ></TextBlock>
            <ComboBox x:Name="BrandSelector" SelectedIndex="0">
                <ComboBoxItem Content="Honda"/>
                <ComboBoxItem Content="Ferrari"/>
                <ComboBoxItem Content="Lada"/>
            </ComboBox>
            <Button Content="Assemble Car" Click="MakeCar" Margin="0,10,0,0"/>
            <TextBlock x:Name="StatusText" Text="" Margin="0,10,0,0"/>
            <TextBlock x:Name="ReportContainer" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="Collapsed">
                <Hyperlink x:Name="ReportLink" Click="OpenReport">
                    Product report here
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
